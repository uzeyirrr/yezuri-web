---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '~/layouts/BaseLayout.astro';
import ServiceDetail from '~/components/ServiceDetail.astro';
import { getServices } from '~/data/services';
import { servicesSlugMap } from '~/i18n/ui';

export const getStaticPaths = (() => {
  return getServices('en').map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}) satisfies GetStaticPaths;

const { service } = Astro.props;
const locale = 'en' as const;
const canonicalPath = `/en/services/${service.slug}`;
const trSlug = servicesSlugMap.en[service.slug];
const alternatePath = `/hizmetler/${trSlug}`;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.title,
  description: service.intro.join(' '),
  provider: { '@id': 'https://yezuri.com/#organization' },
  areaServed: { '@type': 'Country', name: 'Turkey' },
  serviceType: service.title,
};
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  locale={locale}
  canonicalPath={canonicalPath}
  alternatePath={alternatePath}
  structuredData={serviceLd}
>
  <ServiceDetail locale={locale} service={service} />
</BaseLayout>
