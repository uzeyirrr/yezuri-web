---
import { getDictionary, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);

const accents = [
  'linear-gradient(135deg, #E11D2E 0%, #7F0E1A 100%)',
  'linear-gradient(135deg, #FF3B4D 0%, #E11D2E 100%)',
  'linear-gradient(135deg, #7F0E1A 0%, #25252F 100%)',
  'linear-gradient(135deg, #E11D2E 0%, #FF3B4D 70%)',
  'linear-gradient(135deg, #25252F 0%, #E11D2E 120%)',
  'linear-gradient(135deg, #FF3B4D 0%, #7F0E1A 120%)',
];
---

<section id="projects" class="projects" aria-labelledby="projects-title">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{t.projects.eyebrow}</span>
      <h2 id="projects-title">{t.projects.title}</h2>
      <p>{t.projects.subtitle}</p>
    </div>

    <ul class="projects-grid">
      {t.projects.items.map((p, i) => (
        <li class="project-card reveal" style={`transition-delay: ${i * 70}ms`}>
          <div class="project-thumb" style={`background: ${accents[i % accents.length]};`} aria-hidden="true">
            <div class="project-shape"></div>
            <span class="project-tag">{p.category}</span>
          </div>
          <div class="project-body">
            <h3>{p.title}</h3>
            <span class="project-metric">{p.metric}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .project-card {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-elev);
    overflow: hidden;
    transition: transform 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
  }
  .project-card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
  }
  .project-thumb {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    isolation: isolate;
  }
  .project-shape {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.18), transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(0, 0, 0, 0.3), transparent 50%);
    mix-blend-mode: overlay;
  }
  .project-thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: linear-gradient(0deg, rgba(0, 0, 0, 0.45), transparent 50%);
  }
  .project-tag {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    z-index: 2;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: white;
    font-size: 0.75rem;
    font-weight: 500;
  }
  .project-body {
    padding: var(--space-5) var(--space-5) var(--space-5);
  }
  .project-body h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-2);
  }
  .project-metric {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
  }
  .project-metric::before {
    content: '↗';
    font-size: 1rem;
  }
  @media (max-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
