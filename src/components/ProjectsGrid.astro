---
import { Icon } from 'astro-icon/components';
import { getDictionary, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);

const ratios = ['4 / 5', '4 / 3', '16 / 11', '3 / 4', '16 / 10', '1 / 1'];
const viewLabel = locale === 'tr' ? 'Vakayı incele' : 'View case';
---

<section id="projects" class="projects" aria-labelledby="projects-title">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{t.projects.eyebrow}</span>
      <h2 id="projects-title">{t.projects.title}</h2>
      <p>{t.projects.subtitle}</p>
    </div>

    <ul class="projects-grid">
      {t.projects.items.map((p, i) => (
        <li class="project-card reveal" style={`transition-delay: ${i * 70}ms`}>
          <article
            class="project-media"
            style={`aspect-ratio: ${ratios[i % ratios.length]};`}
            tabindex="0"
          >
            <img
              class="project-image"
              src={p.image}
              alt={p.title}
              loading="lazy"
              decoding="async"
            />
            <span class="project-scrim" aria-hidden="true"></span>
            <span class="project-glow" aria-hidden="true"></span>

            <span class="project-tag">{p.category}</span>

            <div class="project-content">
              <h3>{p.title}</h3>
              <div class="project-foot">
                <span class="project-metric">{p.metric}</span>
                <span class="project-cta" aria-hidden="true">
                  <span>{viewLabel}</span>
                  <Icon name="lucide:arrow-up-right" width="16" height="16" />
                </span>
              </div>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .projects-grid {
    column-count: 3;
    column-gap: clamp(1rem, 1.8vw, 1.4rem);
  }
  .project-card {
    display: block;
    width: 100%;
    margin-bottom: clamp(1rem, 1.8vw, 1.4rem);
    break-inside: avoid;
    -webkit-column-break-inside: avoid;
    page-break-inside: avoid;
  }

  .project-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    isolation: isolate;
    cursor: pointer;
    transition: transform 0.5s var(--ease-out), border-color 0.4s var(--ease-out),
      box-shadow 0.5s var(--ease-out);
    will-change: transform;
  }
  .project-media:hover,
  .project-media:focus-visible {
    transform: translateY(-6px);
    border-color: var(--accent-fade);
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(225, 29, 46, 0.18) inset;
  }

  .project-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.8s var(--ease-out), filter 0.5s var(--ease-out);
    filter: saturate(1.05);
  }
  .project-media:hover .project-image,
  .project-media:focus-visible .project-image {
    transform: scale(1.08);
    filter: saturate(1.15) brightness(1.02);
  }

  .project-scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(10, 10, 11, 0.05) 0%, rgba(10, 10, 11, 0.15) 30%, rgba(10, 10, 11, 0.85) 100%);
    transition: opacity 0.5s var(--ease-out);
  }
  .project-media:hover .project-scrim,
  .project-media:focus-visible .project-scrim {
    background:
      linear-gradient(180deg, rgba(10, 10, 11, 0.1) 0%, rgba(10, 10, 11, 0.35) 35%, rgba(10, 10, 11, 0.92) 100%);
  }

  .project-glow {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(120% 80% at 100% 100%, rgba(225, 29, 46, 0.4), transparent 55%);
    mix-blend-mode: screen;
    opacity: 0;
    transition: opacity 0.5s var(--ease-out);
    pointer-events: none;
  }
  .project-media:hover .project-glow,
  .project-media:focus-visible .project-glow {
    opacity: 0.9;
  }

  .project-tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 3;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: rgba(10, 10, 11, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: transform 0.4s var(--ease-out), background 0.4s var(--ease-out);
  }
  .project-media:hover .project-tag,
  .project-media:focus-visible .project-tag {
    transform: translateY(-2px);
    background: rgba(225, 29, 46, 0.4);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .project-content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 3;
    padding: clamp(1rem, 2vw, 1.5rem);
    color: white;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transform: translateY(0);
    transition: transform 0.5s var(--ease-out);
  }
  .project-content h3 {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: white;
    text-shadow: 0 2px 14px rgba(0, 0, 0, 0.55);
  }

  .project-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .project-metric {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-hot);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
  }
  .project-metric::before {
    content: '↗';
    font-size: 1rem;
  }

  .project-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    color: white;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out),
      background 0.4s var(--ease-out);
  }
  .project-media:hover .project-cta,
  .project-media:focus-visible .project-cta {
    opacity: 1;
    transform: translateX(0);
    background: var(--accent);
    border-color: var(--accent);
  }
  .project-cta svg {
    transition: transform 0.4s var(--ease-out);
  }
  .project-media:hover .project-cta svg,
  .project-media:focus-visible .project-cta svg {
    transform: translate(2px, -2px);
  }

  @media (max-width: 900px) {
    .projects-grid {
      column-count: 2;
    }
  }
  @media (max-width: 560px) {
    .projects-grid {
      column-count: 1;
    }
    .project-cta {
      opacity: 1;
      transform: none;
      background: var(--accent);
      border-color: var(--accent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-media,
    .project-media:hover,
    .project-image,
    .project-media:hover .project-image,
    .project-content,
    .project-cta,
    .project-media:hover .project-cta {
      transform: none;
    }
  }
</style>
