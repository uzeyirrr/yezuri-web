---
// Chatwoot canlı sohbet widget'ı (self-hosted: chat.yezuri.com).
// is:inline ile birebir korunur (Astro tarafından bundle edilmez).
---

<script is:inline>
  (function (d, t) {
    var BASE_URL = 'https://chat.yezuri.com/';
    var g = d.createElement(t),
      s = d.getElementsByTagName(t)[0];
    g.src = BASE_URL + '/packs/js/sdk.js';
    g.async = true;
    s.parentNode.insertBefore(g, s);
    g.onload = function () {
      window.chatwootSDK.run({
        websiteToken: 'puJSb8GLNBxQuamnsgFx5crG',
        baseUrl: BASE_URL,
      });
    };
  })(document, 'script');
</script>

<style is:global>
  /* Mobilde Chatwoot balonu/penceresi sağ kenardan taşıyordu (body overflow-x:hidden
     + Chatwoot'un sabit `right` hizalaması). Viewport içinde tutuyoruz. */
  @media (max-width: 668px) {
    .woot-widget-bubble,
    .woot-widget-bubble.woot-elements--right {
      right: 16px !important;
      bottom: 16px !important;
    }
    .woot-widget-holder,
    .woot-widget-holder.woot-elements--right {
      width: 100% !important;
      max-width: 100vw !important;
      right: 0 !important;
      left: 0 !important;
      bottom: 0 !important;
    }
  }
</style>
