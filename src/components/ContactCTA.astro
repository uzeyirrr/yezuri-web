---
import { getDictionary, contactInfo, whatsappLink, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
const wa = whatsappLink(
  locale === 'tr'
    ? 'Merhaba, projemizi konuşmak istiyorum.'
    : 'Hi, I would like to discuss our project.',
);
---

<section id="contact" class="contact" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact-card reveal">
      <div class="contact-shape" aria-hidden="true"></div>
      <div class="contact-content">
        <span class="eyebrow">{t.contact.eyebrow}</span>
        <h2 id="contact-title">{t.contact.title}</h2>
        <p>{t.contact.subtitle}</p>

        <div class="contact-channels">
          <a class="channel channel-wa" href={wa} target="_blank" rel="noopener" data-magnetic>
            <span class="channel-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.9-4.44 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01Zm-7.01 15.24a8.21 8.21 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.24 8.24 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24a8.18 8.18 0 0 1 8.23 8.24c0 4.54-3.7 8.24-8.23 8.24Z"/></svg>
            </span>
            <span class="channel-text">
              <strong>{t.contact.whatsapp}</strong>
              <span>{contactInfo.phone}</span>
            </span>
          </a>

          <a class="channel" href={`mailto:${contactInfo.email}`}>
            <span class="channel-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
            </span>
            <span class="channel-text">
              <strong>{t.contact.email}</strong>
              <span>{contactInfo.email}</span>
            </span>
          </a>

          <a class="channel" href={`tel:${contactInfo.phone.replace(/\s/g, '')}`}>
            <span class="channel-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 13 13 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 13 13 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            </span>
            <span class="channel-text">
              <strong>{t.contact.phone}</strong>
              <span>{contactInfo.phone}</span>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card {
    position: relative;
    padding: clamp(2.5rem, 6vw, 4.5rem);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--border-strong);
    background: linear-gradient(140deg, var(--bg-elev) 0%, var(--bg-elev-2) 100%);
    isolation: isolate;
  }
  .contact-shape {
    position: absolute;
    inset: -20%;
    z-index: -1;
    background:
      radial-gradient(600px circle at 80% 10%, var(--accent-glow), transparent 50%),
      radial-gradient(500px circle at 10% 90%, rgba(127, 14, 26, 0.4), transparent 50%);
    opacity: 0.6;
    animation: shape-float 16s var(--ease-in-out) infinite;
  }
  .contact-content {
    max-width: 1000px;
  }
  .contact-content h2 {
    margin-top: var(--space-4);
    max-width: 18ch;
  }
  .contact-content > p {
    margin-top: var(--space-4);
    max-width: 60ch;
    font-size: 1.05rem;
  }
  .contact-channels {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .channel {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-glass);
    transition: transform 0.3s var(--ease-out), border-color 0.3s var(--ease-out),
      background 0.3s var(--ease-out);
  }
  .channel:hover {
    transform: translateY(-3px);
    border-color: var(--border-strong);
    background: var(--surface-glass-hover);
  }
  .channel-wa {
    background: linear-gradient(135deg, rgba(37, 211, 102, 0.18), rgba(37, 211, 102, 0.04));
    border-color: rgba(37, 211, 102, 0.4);
  }
  .channel-wa:hover {
    background: linear-gradient(135deg, rgba(37, 211, 102, 0.3), rgba(37, 211, 102, 0.08));
    border-color: rgba(37, 211, 102, 0.7);
  }
  .channel-icon {
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    border-radius: var(--radius-md);
    background: rgba(225, 29, 46, 0.12);
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .channel-wa .channel-icon {
    background: #25d366;
    color: white;
  }
  .channel-text strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 2px;
  }
  .channel-text span {
    font-size: 0.86rem;
    color: var(--text-mute);
  }
  @keyframes shape-float {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-20px, 20px);
    }
  }
  @media (max-width: 900px) {
    .contact-channels {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .contact-shape {
      animation: none;
    }
  }
</style>
