---
import type { BlogPost } from '~/utils/blog';
import { formatDate, readingTime, blogPath } from '~/utils/blog';
import type { Locale } from '~/i18n/ui';

export interface Props {
  post: BlogPost;
  locale?: Locale;
  featured?: boolean;
}

const { post, locale = 'tr', featured = false } = Astro.props;
const { title, description, pubDate, category, accent, cover } = post.data;
const href = blogPath(locale, post.id);
---

<article class={`blog-card${featured ? ' blog-card-featured' : ''}`} style={`--card-accent: ${accent}`}>
  <a class="blog-card-link" href={href}>
    <div class="blog-card-cover" aria-hidden="true">
      {cover && <img class="blog-card-img" src={cover} alt="" loading="lazy" decoding="async" />}
      <span class="blog-card-cat">{category}</span>
    </div>
    <div class="blog-card-body">
      <h2 class="blog-card-title">{title}</h2>
      <p class="blog-card-desc">{description}</p>
      <div class="blog-card-meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate, locale)}</time>
        <span class="blog-card-dot" aria-hidden="true">•</span>
        <span>{readingTime(post.body ?? '', locale)}</span>
      </div>
    </div>
  </a>
</article>

<style>
  .blog-card {
    position: relative;
    border-radius: var(--radius-lg);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: transform 0.35s var(--ease-out), border-color 0.35s var(--ease-out),
      box-shadow 0.35s var(--ease-out);
  }
  .blog-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent-fade);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.28);
  }
  .blog-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .blog-card-cover {
    position: relative;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: flex-end;
    padding: var(--space-4);
    background:
      radial-gradient(120% 120% at 0% 0%, color-mix(in srgb, var(--card-accent) 55%, transparent), transparent 60%),
      linear-gradient(135deg, color-mix(in srgb, var(--card-accent) 30%, #14141a), #0c0c10);
  }
  .blog-card-cover::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 28px 28px;
    opacity: 0.4;
    mask-image: radial-gradient(ellipse 80% 80% at 80% 20%, black, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 80% 20%, black, transparent 75%);
  }
  .blog-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .blog-card-cat {
    position: relative;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--card-accent) 75%, transparent);
    backdrop-filter: blur(6px);
  }
  .blog-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5);
    flex: 1;
  }
  .blog-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .blog-card:hover .blog-card-title {
    color: var(--accent);
  }
  .blog-card-desc {
    color: var(--text-mute);
    font-size: 0.92rem;
    line-height: 1.6;
    flex: 1;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--text-mute);
    margin-top: auto;
  }
  .blog-card-dot {
    color: var(--accent);
  }

  /* Öne çıkan ilk yazı geniş yerleşim */
  @media (min-width: 720px) {
    .blog-card-featured {
      grid-column: 1 / -1;
    }
    .blog-card-featured .blog-card-link {
      flex-direction: row;
    }
    .blog-card-featured .blog-card-cover {
      aspect-ratio: auto;
      flex: 1 1 45%;
      min-height: 260px;
    }
    .blog-card-featured .blog-card-body {
      flex: 1 1 55%;
      justify-content: center;
      padding: var(--space-7);
    }
    .blog-card-featured .blog-card-title {
      font-size: 1.6rem;
    }
    .blog-card-featured .blog-card-desc {
      font-size: 1rem;
    }
  }
</style>
