---
import { getDictionary, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
---

<section id="process" class="process" aria-labelledby="process-title">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{t.process.eyebrow}</span>
      <h2 id="process-title">{t.process.title}</h2>
      <p>{t.process.subtitle}</p>
    </div>

    <ol class="process-line">
      {t.process.steps.map((step, i) => (
        <li class="process-step reveal" style={`transition-delay: ${i * 100}ms`}>
          <div class="process-num">{step.step}</div>
          <h3>{step.title}</h3>
          <p>{step.detail}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process-line {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    counter-reset: process;
    position: relative;
  }
  .process-line::before {
    content: '';
    position: absolute;
    top: 36px;
    left: 5%;
    right: 5%;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-fade), var(--accent-fade), transparent);
    z-index: 0;
  }
  .process-step {
    position: relative;
    padding-top: var(--space-3);
    z-index: 1;
  }
  .process-num {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-pill);
    background: var(--bg-elev-2);
    border: 1px solid var(--border-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--accent);
    margin-bottom: var(--space-4);
    box-shadow: inset 0 0 0 4px var(--bg-base), 0 8px 24px rgba(0, 0, 0, 0.4);
    position: relative;
  }
  .process-num::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--accent), transparent 50%, var(--accent));
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s var(--ease-out);
    animation: rotate-glow 4s linear infinite;
  }
  .process-step:hover .process-num::after {
    opacity: 0.7;
  }
  .process-step h3 {
    margin-bottom: var(--space-3);
  }
  .process-step p {
    font-size: 0.93rem;
  }
  @keyframes rotate-glow {
    to {
      transform: rotate(360deg);
    }
  }
  @media (max-width: 880px) {
    .process-line {
      grid-template-columns: repeat(2, 1fr);
    }
    .process-line::before {
      display: none;
    }
  }
  @media (max-width: 540px) {
    .process-line {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .process-num::after {
      animation: none;
    }
  }
</style>
