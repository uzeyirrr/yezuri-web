---
import { getDictionary, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
---

<section class="testi" aria-labelledby="testi-title">
  <div class="container">
    <div class="section-head reveal">
      <span class="eyebrow">{t.testimonials.eyebrow}</span>
      <h2 id="testi-title">{t.testimonials.title}</h2>
    </div>

    <ul class="testi-grid">
      {t.testimonials.items.map((item, i) => (
        <li class="testi-card reveal" style={`transition-delay: ${i * 100}ms`}>
          <svg class="testi-quote" viewBox="0 0 32 32" width="36" height="36" fill="currentColor" aria-hidden="true">
            <path d="M10.5 8C6.4 8 3 11.4 3 15.5S6.4 23 10.5 23H11V14H7v-1c0-1.7 1.3-3 3-3h.5V8Zm14 0c-4.1 0-7.5 3.4-7.5 7.5S20.4 23 24.5 23h.5V14h-4v-1c0-1.7 1.3-3 3-3h.5V8Z"/>
          </svg>
          <blockquote>{item.quote}</blockquote>
          <div class="testi-author">
            <span class="testi-avatar" aria-hidden="true">{item.author.split(' ').map((p) => p[0]).join('')}</span>
            <div>
              <strong>{item.author}</strong>
              <span>{item.role}</span>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }
  .testi-card {
    position: relative;
    padding: var(--space-6);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, var(--bg-elev) 0%, var(--bg-elev-2) 100%);
    transition: border-color 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }
  .testi-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-fade);
  }
  .testi-quote {
    color: var(--accent);
    opacity: 0.5;
    margin-bottom: var(--space-4);
  }
  blockquote {
    font-size: 1.02rem;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: var(--space-5);
  }
  .testi-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  .testi-avatar {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-pill);
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-deep) 100%);
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .testi-author strong {
    display: block;
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .testi-author span {
    font-size: 0.82rem;
    color: var(--text-mute);
  }
  @media (max-width: 980px) {
    .testi-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
