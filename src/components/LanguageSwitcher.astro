---
import type { Locale } from '~/i18n/ui';
import { alternateLocale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
  /** Path to switch to in the alternate locale, including locale prefix when applicable */
  alternatePath: string;
}

const { locale, alternatePath } = Astro.props;
const alt = alternateLocale(locale);
---

<a href={alternatePath} class="lang-switch" aria-label={`Switch to ${alt.toUpperCase()}`}>
  <span class:list={['lang-pill', locale === 'tr' && 'active']}>TR</span>
  <span class="lang-sep" aria-hidden="true">/</span>
  <span class:list={['lang-pill', locale === 'en' && 'active']}>EN</span>
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    background: var(--surface-glass);
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--text-mute);
    transition: background 0.3s var(--ease-out), border-color 0.3s var(--ease-out);
  }
  .lang-switch:hover {
    background: var(--surface-glass-hover);
    border-color: var(--border-strong);
  }
  .lang-pill {
    transition: color 0.3s var(--ease-out);
  }
  .lang-pill.active {
    color: var(--accent);
  }
  .lang-sep {
    color: var(--text-dim);
  }
</style>
