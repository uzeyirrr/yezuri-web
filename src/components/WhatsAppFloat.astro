---
import { whatsappLink, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const message =
  locale === 'tr'
    ? 'Merhaba, Yezuri ile bir proje konuşmak istiyorum.'
    : 'Hi, I would like to discuss a project with Yezuri.';
const wa = whatsappLink(message);
const label = locale === 'tr' ? 'WhatsApp ile yaz' : 'Message us on WhatsApp';
---

<a
  href={wa}
  target="_blank"
  rel="noopener"
  class="wa-float"
  aria-label={label}
>
  <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
    <path fill="currentColor" d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.9-4.44 9.9-9.91 0-2.65-1.03-5.14-2.9-7.01Zm-7.01 15.24h-.01a8.21 8.21 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.24 8.24 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.15.16-.29.18-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.47-1.39-1.72-.14-.25-.01-.39.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.16.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.49-.41-.42-.56-.43h-.48c-.16 0-.41.06-.62.31-.21.25-.81.79-.81 1.93s.83 2.24.95 2.4c.12.16 1.64 2.5 3.97 3.51.55.24.99.39 1.33.5.56.18 1.07.15 1.47.09.45-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.16-.48-.28Z"/>
  </svg>
  <span class="wa-tooltip">{label}</span>
</a>

<style>
  .wa-float {
    position: fixed;
    right: clamp(1rem, 3vw, 1.5rem);
    bottom: clamp(1rem, 3vw, 1.5rem);
    z-index: 90;
    width: 60px;
    height: 60px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-pill);
    background: #25d366;
    color: white;
    box-shadow: 0 12px 32px rgba(37, 211, 102, 0.4);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
    animation: wa-pulse 2.4s ease-in-out infinite;
  }
  .wa-float:hover {
    transform: translateY(-4px) scale(1.06);
    box-shadow: 0 18px 44px rgba(37, 211, 102, 0.55);
    animation: none;
  }
  .wa-tooltip {
    position: absolute;
    right: calc(100% + 14px);
    top: 50%;
    transform: translateY(-50%) translateX(8px);
    padding: 8px 14px;
    background: var(--bg-elev-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s var(--ease-out), transform 0.25s var(--ease-out);
  }
  .wa-float:hover .wa-tooltip {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }
  @keyframes wa-pulse {
    0%,
    100% {
      box-shadow: 0 12px 32px rgba(37, 211, 102, 0.4), 0 0 0 0 rgba(37, 211, 102, 0.5);
    }
    50% {
      box-shadow: 0 12px 32px rgba(37, 211, 102, 0.4), 0 0 0 14px rgba(37, 211, 102, 0);
    }
  }
  @media (max-width: 540px) {
    .wa-tooltip {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-float {
      animation: none;
    }
  }
</style>
