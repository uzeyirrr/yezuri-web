---
export interface Props {
  eyebrow?: string;
  title: string;
  updatedLabel: string;
  updated: string;
}

const { eyebrow, title, updatedLabel, updated } = Astro.props;
---

<section class="legal-doc">
  <div class="container legal-inner">
    <header class="legal-head">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h1>{title}</h1>
      <p class="legal-updated">{updatedLabel}: {updated}</p>
    </header>
    <div class="legal-body">
      <slot />
    </div>
  </div>
</section>

<!-- is:global: slot içeriği üst bileşenin scope'unu taşıdığı için prose stilleri
     benzersiz .legal-* sınıfları altında global tanımlanır. -->
<style is:global>
  .legal-doc {
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .legal-inner {
    max-width: 820px;
  }
  .legal-head {
    margin-bottom: clamp(2rem, 5vw, 3rem);
  }
  .legal-head h1 {
    margin-top: var(--space-4);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
  }
  .legal-updated {
    margin-top: var(--space-3);
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  .legal-body {
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--text-mute);
  }
  .legal-body > h2:first-child {
    margin-top: 0;
  }
  .legal-body h2 {
    margin-top: var(--space-7);
    margin-bottom: var(--space-4);
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    color: var(--text);
  }
  .legal-body h3 {
    margin-top: var(--space-5);
    margin-bottom: var(--space-3);
    font-size: 1.15rem;
    color: var(--text);
  }
  .legal-body p {
    margin-bottom: var(--space-4);
  }
  .legal-body ul {
    margin: 0 0 var(--space-4);
    padding-left: 1.3rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .legal-body li {
    list-style: disc;
    line-height: 1.6;
  }
  .legal-body a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .legal-body strong {
    color: var(--text);
  }
</style>
