---
import { render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import { formatDate, readingTime, blogUi, type BlogPost } from '~/utils/blog';
import { whatsappLink, type Locale } from '~/i18n/ui';

export interface Props {
  post: BlogPost;
  locale: Locale;
}

const { post, locale } = Astro.props;
const ui = blogUi[locale];
const { title, description, pubDate, author, category, tags, accent, cover } = post.data;
const { Content } = await render(post);
const wa = whatsappLink(ui.waMessage(title));
const blogHref = locale === 'tr' ? '/blog' : '/en/blog';
---

<article class="post" style={`--post-accent: ${accent}`}>
  <div class="container post-head-wrap">
    <nav class="post-breadcrumb" aria-label="Breadcrumb">
      <a href={blogHref}>{ui.blog}</a>
      <span aria-hidden="true">/</span>
      <span>{category}</span>
    </nav>
    <header class="post-head">
      <span class="post-cat">{category}</span>
      <h1>{title}</h1>
      <p class="post-lead">{description}</p>
      <div class="post-meta">
        <span>{author}</span>
        <span class="post-meta-dot" aria-hidden="true">•</span>
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate, locale)}</time>
        <span class="post-meta-dot" aria-hidden="true">•</span>
        <span>{readingTime(post.body ?? '', locale)}</span>
      </div>
    </header>
  </div>

  {cover ? (
    <img class="post-cover post-cover-img" src={cover} alt="" fetchpriority="high" decoding="async" />
  ) : (
    <div class="post-cover" aria-hidden="true"></div>
  )}

  <div class="container">
    <div class="blog-prose">
      <Content />
    </div>

    {tags.length > 0 && (
      <ul class="post-tags" aria-label="Tags">
        {tags.map((tag) => <li>#{tag}</li>)}
      </ul>
    )}

    <aside class="post-cta">
      <div class="post-cta-text">
        <h2>{ui.ctaTitle}</h2>
        <p>{ui.ctaText}</p>
      </div>
      <a class="btn btn-primary" href={wa} target="_blank" rel="noopener" data-magnetic>
        {ui.ctaButton}
        <Icon name="lucide:arrow-right" width="16" height="16" />
      </a>
    </aside>

    <a class="post-back" href={blogHref}>
      <Icon name="lucide:arrow-left" width="16" height="16" />
      {ui.back}
    </a>
  </div>
</article>

<style is:global>
  .post {
    padding-top: clamp(6rem, 13vw, 9rem);
    padding-bottom: clamp(4rem, 9vw, 7rem);
  }
  .post-head-wrap,
  .post .container {
    max-width: 800px;
  }
  .post-breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--text-dim);
    margin-bottom: var(--space-5);
  }
  .post-breadcrumb a {
    color: var(--text-mute);
  }
  .post-breadcrumb a:hover {
    color: var(--accent);
  }
  .post-cat {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    padding: 6px 12px;
    border-radius: var(--radius-pill);
    background: var(--post-accent);
  }
  .post-head h1 {
    margin-top: var(--space-4);
    font-size: clamp(2rem, 4.6vw, 3.1rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .post-lead {
    margin-top: var(--space-4);
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    line-height: 1.55;
    color: var(--text-mute);
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: var(--space-5);
    font-size: 0.88rem;
    color: var(--text-dim);
    font-family: var(--font-display);
  }
  .post-meta-dot {
    color: var(--post-accent);
  }
  .post-cover {
    max-width: 1100px;
    margin: clamp(2rem, 5vw, 3rem) auto;
    padding-inline: var(--space-4);
    height: clamp(180px, 28vw, 340px);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(120% 140% at 100% 0%, color-mix(in srgb, var(--post-accent) 50%, transparent), transparent 60%),
      linear-gradient(135deg, color-mix(in srgb, var(--post-accent) 28%, #14141a), #0b0b0f);
    position: relative;
    overflow: hidden;
  }
  .post-cover-img {
    display: block;
    padding-inline: 0;
    object-fit: cover;
    background: linear-gradient(135deg, color-mix(in srgb, var(--post-accent) 28%, #14141a), #0b0b0f);
  }
  .post-cover:not(.post-cover-img)::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.4;
    mask-image: radial-gradient(ellipse 90% 90% at 85% 15%, black, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 90% 90% at 85% 15%, black, transparent 75%);
  }

  /* --- Prose --- */
  .blog-prose {
    font-size: 1.06rem;
    line-height: 1.75;
    color: var(--text);
  }
  .blog-prose > * + * {
    margin-top: 1.35em;
  }
  .blog-prose h2 {
    margin-top: 2.4em;
    font-size: clamp(1.5rem, 2.6vw, 1.9rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    scroll-margin-top: 6rem;
  }
  .blog-prose h3 {
    margin-top: 1.8em;
    font-size: clamp(1.2rem, 2vw, 1.4rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .blog-prose p,
  .blog-prose li {
    color: var(--text-mute);
  }
  .blog-prose strong {
    color: var(--text);
    font-weight: 600;
  }
  .blog-prose a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .blog-prose ul,
  .blog-prose ol {
    padding-left: 1.4em;
  }
  .blog-prose ul {
    list-style: disc;
  }
  .blog-prose ol {
    list-style: decimal;
  }
  .blog-prose li + li {
    margin-top: 0.5em;
  }
  .blog-prose li::marker {
    color: var(--accent);
  }
  .blog-prose blockquote {
    margin-block: 1.8em;
    padding: var(--space-4) var(--space-5);
    border-left: 3px solid var(--accent);
    border-radius: 0 var(--radius-md, 12px) var(--radius-md, 12px) 0;
    background: var(--accent-mute);
    color: var(--text);
  }
  .blog-prose blockquote p {
    color: var(--text);
    margin: 0;
  }
  .blog-prose code {
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.9em;
    padding: 0.15em 0.4em;
    border-radius: 6px;
    background: var(--bg-elev-2);
    color: var(--accent);
  }
  .blog-prose table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.94rem;
    display: block;
    overflow-x: auto;
  }
  .blog-prose th,
  .blog-prose td {
    padding: 12px 14px;
    border: 1px solid var(--border);
    text-align: left;
  }
  .blog-prose th {
    background: var(--bg-elev);
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 600;
  }
  .blog-prose td {
    color: var(--text-mute);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .post-tags li {
    font-size: 0.82rem;
    color: var(--text-mute);
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
  }

  .post-cta {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(90deg, var(--accent-mute), transparent 70%),
      var(--bg-elev);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-5);
    flex-wrap: wrap;
  }
  .post-cta h2 {
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .post-cta p {
    margin-top: 6px;
    color: var(--text-mute);
    font-size: 0.95rem;
  }
  .post-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: clamp(2rem, 4vw, 2.5rem);
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--text-mute);
  }
  .post-back:hover {
    color: var(--accent);
  }
</style>
