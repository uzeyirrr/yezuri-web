---
import { getDictionary, type Locale } from '~/i18n/ui';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: t.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};
---

<section id="faq" class="faq" aria-labelledby="faq-title">
  <div class="container faq-inner">
    <div class="faq-head reveal">
      <span class="eyebrow">{t.faq.eyebrow}</span>
      <h2 id="faq-title">{t.faq.title}</h2>
    </div>

    <div class="faq-list">
      {t.faq.items.map((item, i) => (
        <details class="faq-item reveal" style={`transition-delay: ${i * 60}ms`}>
          <summary>
            <span>{item.q}</span>
            <span class="faq-icon" aria-hidden="true">+</span>
          </summary>
          <div class="faq-answer">
            <p>{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<style>
  .faq-inner {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-7);
    align-items: start;
  }
  .faq-head {
    position: sticky;
    top: 100px;
  }
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--bg-elev);
    overflow: hidden;
    transition: border-color 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }
  .faq-item[open] {
    border-color: var(--accent-fade);
    background: linear-gradient(180deg, var(--bg-elev) 0%, var(--bg-elev-2) 100%);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
    color: var(--text);
    transition: color 0.2s var(--ease-out);
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item[open] summary {
    color: var(--accent);
  }
  .faq-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-pill);
    background: var(--surface-glass);
    border: 1px solid var(--border);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.1rem;
    transition: transform 0.3s var(--ease-out), background 0.3s var(--ease-out);
  }
  .faq-item[open] .faq-icon {
    transform: rotate(45deg);
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }
  .faq-answer {
    padding: 0 var(--space-5) var(--space-5);
  }
  .faq-answer p {
    color: var(--text-mute);
    font-size: 0.95rem;
    line-height: 1.65;
  }
  @media (max-width: 880px) {
    .faq-inner {
      grid-template-columns: 1fr;
    }
    .faq-head {
      position: static;
    }
  }
</style>
