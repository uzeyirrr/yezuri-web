---
import { getDictionary, localizedPath, whatsappLink, type Locale } from '~/i18n/ui';
import Logo from './Logo.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getDictionary(locale);
const home = localizedPath(locale, '/');

const navLinks = [
  { href: `${home}#services`, label: t.nav.services },
  { href: `${home}#process`, label: t.nav.process },
  { href: `${home}#projects`, label: t.nav.projects },
  { href: `${home}#faq`, label: locale === 'tr' ? 'SSS' : 'FAQ' },
  { href: `${home}#contact`, label: t.nav.contact },
];

const alternatePath = locale === 'tr' ? '/en/' : '/';

const wa = whatsappLink(locale === 'tr' ? 'Merhaba, Yezuri ile çalışmak istiyorum.' : 'Hi, I would like to work with Yezuri.');
---

<header class="site-header" data-header>
  <div class="header-wrap container">
    <div class="header-row">
      <Logo locale={locale} size="md" />

      <nav class="nav-desktop" aria-label="Primary">
        <ul>
          {navLinks.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <div class="header-actions">
        <ThemeToggle locale={locale} />
        <LanguageSwitcher locale={locale} alternatePath={alternatePath} />
        <a class="btn btn-primary header-cta" href={wa} target="_blank" rel="noopener" data-magnetic>
          {t.nav.cta}
        </a>
        <button
          class="nav-toggle"
          type="button"
          aria-label="Menüyü aç/kapa"
          aria-expanded="false"
          aria-controls="nav-panel"
          data-nav-toggle
        >
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  <div class="nav-panel" id="nav-panel" data-nav-panel>
    <div class="nav-panel-inner">
      <span class="nav-panel-eyebrow">{locale === 'tr' ? 'Menü' : 'Menu'}</span>
      <ul>
        {navLinks.map((l, i) => (
          <li style={`--delay: ${0.08 + i * 0.05}s`}>
            <a href={l.href}>
              <span>{l.label}</span>
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 5l7 7-7 7"/>
              </svg>
            </a>
          </li>
        ))}
      </ul>
      <div class="nav-panel-foot">
        <a class="btn btn-primary nav-panel-cta" href={wa} target="_blank" rel="noopener">
          {t.nav.cta}
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <span class="nav-panel-status">
          <span class="nav-panel-dot" aria-hidden="true"></span>
          {t.hero.status}
        </span>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: clamp(0.5rem, 1.4vw, 1rem);
    z-index: 100;
    padding-top: clamp(0.5rem, 1.4vw, 1rem);
    transition: transform 0.4s var(--ease-out);
  }
  .site-header.hidden {
    transform: translateY(calc(-100% - 2rem));
  }
  .header-wrap {
    pointer-events: none;
  }
  .header-row {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: 8px 8px 8px 20px;
    background: var(--surface-glass);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    transition: background 0.3s var(--ease-out), border-color 0.3s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
  }
  .site-header.scrolled .header-row {
    background: var(--surface-glass-hover);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-md);
  }
  .nav-desktop ul {
    display: flex;
    gap: 2px;
  }
  .nav-desktop a {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-mute);
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    transition: color 0.2s var(--ease-out), background 0.2s var(--ease-out);
  }
  .nav-desktop a:hover,
  .nav-desktop a:focus-visible {
    color: var(--text);
    background: var(--surface-glass-hover);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .header-cta {
    padding: 10px 18px;
    font-size: 0.88rem;
  }
  .nav-toggle {
    display: none;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: var(--surface-glass);
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text);
    border-radius: 1px;
    transition: transform 0.3s var(--ease-out), opacity 0.3s var(--ease-out),
      background 0.3s var(--ease-out);
  }
  .nav-toggle[aria-expanded='true'] {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 6px 24px var(--accent-glow);
  }
  .nav-toggle[aria-expanded='true'] span {
    background: #ffffff;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .nav-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .nav-panel {
    display: none;
  }
  @media (max-width: 880px) {
    .nav-desktop {
      display: none;
    }
    .header-cta {
      display: none;
    }
    .nav-toggle {
      display: inline-flex;
    }
    .nav-panel {
      display: block;
      position: fixed;
      inset: 0;
      background: var(--bg-base);
      backdrop-filter: saturate(180%) blur(24px);
      -webkit-backdrop-filter: saturate(180%) blur(24px);
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.35s var(--ease-out), visibility 0.35s;
      z-index: 99;
    }
    .nav-panel.open {
      opacity: 1;
      visibility: visible;
    }
    .nav-panel-inner {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: calc(env(safe-area-inset-top, 0px) + 84px) clamp(1.5rem, 6vw, 2.25rem) clamp(1.5rem, 6vw, 2.25rem);
      overflow-y: auto;
    }
    .nav-panel-eyebrow {
      font-family: var(--font-display);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-mute);
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);
    }
    .nav-panel.open .nav-panel-eyebrow {
      opacity: 1;
      transform: none;
      transition-delay: 0.05s;
    }
    .nav-panel ul {
      display: flex;
      flex-direction: column;
      margin-top: var(--space-5);
      border-top: 1px solid var(--border);
    }
    .nav-panel li {
      border-bottom: 1px solid var(--border);
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.45s var(--ease-out), transform 0.45s var(--ease-out);
    }
    .nav-panel.open li {
      opacity: 1;
      transform: none;
      transition-delay: var(--delay, 0s);
    }
    .nav-panel li a {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      padding: var(--space-4) 0;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: clamp(1.5rem, 7vw, 2rem);
      letter-spacing: -0.02em;
      color: var(--text);
      transition: color 0.2s var(--ease-out), padding-left 0.3s var(--ease-out);
    }
    .nav-panel li a svg {
      flex-shrink: 0;
      color: var(--text-dim);
      transition: color 0.2s var(--ease-out), transform 0.3s var(--ease-out);
    }
    .nav-panel li a:hover,
    .nav-panel li a:active,
    .nav-panel li a:focus-visible {
      color: var(--accent);
      padding-left: var(--space-3);
    }
    .nav-panel li a:hover svg,
    .nav-panel li a:active svg,
    .nav-panel li a:focus-visible svg {
      color: var(--accent);
      transform: translateX(4px);
    }
    .nav-panel-foot {
      margin-top: auto;
      padding-top: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
    }
    .nav-panel.open .nav-panel-foot {
      opacity: 1;
      transform: none;
      transition-delay: 0.4s;
    }
    .nav-panel-cta {
      width: 100%;
      justify-content: center;
      padding: 16px 24px;
      font-size: 1rem;
      gap: 10px;
    }
    .nav-panel-status {
      display: inline-flex;
      align-items: center;
      align-self: center;
      gap: 10px;
      font-family: var(--font-display);
      font-size: 0.82rem;
      color: var(--text-mute);
    }
    .nav-panel-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #2bd96b;
      box-shadow: 0 0 12px rgba(43, 217, 107, 0.4);
    }
  }
</style>
